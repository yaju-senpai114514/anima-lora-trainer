# 4_sweep_grid.py 전용 통합 설정 — sweep 스크립트가 config.env 를 source 해
#   PATH_MODEL / PATH_QWEN / PATH_VAE / NETWORK_DIM / MAX_TRAIN_EPOCHS 를 읽는다.
#   cp config.env.example config.env  후 본인 환경에 맞게 수정.
# (config.env 는 .gitignore 로 커밋되지 않는다.)

# 모델 경로. 큰따옴표 안에서는 ~ 가 확장되지 않으므로 반드시 $HOME 사용.
PATH_COMFYUI="$HOME/workspace/ComfyUI"
PATH_MODEL="$PATH_COMFYUI/models/diffusion_models/anima_baseV10.safetensors"
PATH_QWEN="$PATH_COMFYUI/models/text_encoders/qwen_3_06b_base.safetensors"
PATH_VAE="$PATH_COMFYUI/models/vae/qwen_image_vae.safetensors"

NETWORK_DIM=32          # 학습 때 쓴 LoRA rank (체크포인트 파일명 anima_<name>_r<dim> 매칭에 사용)
MAX_TRAIN_EPOCHS=24     # 최종 에폭 = 이 값 (스윕이 최종 체크포인트를 찾는 기준)
