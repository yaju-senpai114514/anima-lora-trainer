# 트리거(데이터셋)별 학습 하이퍼파라미터 — 3_run_training*.sh <trigger> 가 source 한다.
#   cp config.trigger.env.example config.<trigger>.env  후 값 수정.
#   예: cp config.trigger.env.example config.mychar.env
# (config.*.env 는 .gitignore 로 커밋되지 않는다. 모델 경로는 config_model.env 에서 공통으로 읽음.)

# --- LoRA ---
NETWORK_DIM=32
NETWORK_ALPHA=32

# --- 배치/최적화 ---
# BATCH_SIZE 는 **글로벌 배치**다. 학습 스크립트가 GPU 수로 나눠 GPU당 배치(--train_batch_size)로 넘긴다.
#   1gpu: 4=4×1   2gpu: 4=2×2   4gpu: 4=4×1   (같은 toml 로 셋 다 돈다)
BATCH_SIZE=4
GRADIENT_ACC_STEPS=1
LR="2e-5"
LR_SCHED="cosine"
LR_WARMUP_STEPS=100
EPOCHS=24
SAVE_EVERY_N_EPOCHS=2

# gradient checkpointing: 1/true=활성(VRAM↓,느림), 0/false=비활성(속도↑,VRAM↑). 기본 1
GRADIENT_CHECKPOINTING=1

# --- 선택 변수 (필요할 때만) ---
# DATASET_TOML="dataset/<trigger>_multires.toml"   # 커스텀 dataset_config(멀티해상도 등). 기본 dataset/<trigger>.toml
# SEED=42                                          # 멀티GPU 캡션 셔플 일관성. 미설정 시 랜덤
# OUT_DIR="output/<trigger>"                       # 출력 경로 오버라이드. 미설정 시 output/<trigger>_gb<배치>_lr<LR>_ep<EPOCHS>
